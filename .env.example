# PostgreSQL
POSTGRES_DB=sheet_music
POSTGRES_USER=sheet_user
POSTGRES_PASSWORD=sheet_pass

# Spring Boot DataSource
# Docker Compose: DB URL is auto-configured (postgres service name)
# Local dev (without Docker): 이 .env 를 저장소 루트에 두면 spring-dotenv 라이브러리가
# 기동 시 자동으로 읽어 환경변수로 반영한다(Gradle bootRun, IntelliJ Run/Debug, jar 실행 등
# 어떤 launch 방식이든 동일하게 동작). 운영 배포용 jar에는 포함되지 않음(developmentOnly).
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/sheet_music
SPRING_DATASOURCE_USERNAME=sheet_user
SPRING_DATASOURCE_PASSWORD=sheet_pass
# 운영(Supabase) DB에 붙이고 싶으면 위 3줄 대신 Supabase 대시보드 → Settings → Database →
# Connection string(Session pooler, 5432)의 실제 값으로 교체:
# SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres
# SPRING_DATASOURCE_USERNAME=postgres.<project-ref>
# SPRING_DATASOURCE_PASSWORD=<supabase-db-password>
# ⚠️ 운영 DB 쓰기까지 그대로 반영됨(회원가입·곡 편집/삭제 등). 순수 조회만 필요하면
# 대신 읽기전용 MCP(.mcp.json 의 supabase-db, SUPABASE_READONLY_URL)를 사용할 것.

# Server
PORT=8080

# Storage (local | r2)
STORAGE_TYPE=local
# STORAGE_LOCAL_PATH=./uploads  # local 모드 기본값

# Cloudflare R2 (STORAGE_TYPE=r2 일 때 필요)
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY=<your-access-key-id>
# R2_SECRET_KEY=<your-secret-access-key>
# R2_BUCKET=worship-sheet

# 로컬 디버그 로깅 (선택, 기본값은 운영과 동일하게 조용함)
# 요청 로그(DispatcherServlet)와 실행되는 SQL/바인드 파라미터를 콘솔에서 보고 싶을 때 주석 해제
# LOCAL_WEB_LOG_LEVEL=DEBUG
# LOCAL_SQL_LOG_LEVEL=DEBUG
# LOCAL_SQL_BIND_LOG_LEVEL=TRACE
