# PostgreSQL
POSTGRES_DB=sheet_music
POSTGRES_USER=sheet_user
POSTGRES_PASSWORD=sheet_pass

# Spring Boot DataSource
# Docker Compose: DB URL is auto-configured (postgres service name)
# Local dev (without Docker): set the URL below
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/sheet_music
SPRING_DATASOURCE_USERNAME=sheet_user
SPRING_DATASOURCE_PASSWORD=sheet_pass

# Server
PORT=8080
