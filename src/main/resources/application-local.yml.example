# 로컬 백엔드를 운영(Supabase) DB에 붙일 때 사용하는 프로필 템플릿.
#
# 사용법:
#   1) 이 파일을 같은 폴더에 application-local.yml 로 복사 (그 파일은 .gitignore 처리되어 커밋되지 않음)
#   2) 아래 값을 Supabase 대시보드 → Settings → Database → Connection string (Session pooler, 5432)에서
#      가져온 실제 값으로 채움
#   3) 실행 시 SPRING_PROFILES_ACTIVE=local 로 이 프로필을 켜야만 적용됨(안 켜면 기존처럼 로컬 Postgres 기본값 사용)
#      JAVA_HOME="D:/03_DEV/jdk/openjdk-17" SPRING_PROFILES_ACTIVE=local ./gradlew bootRun
#
# ⚠️ 운영 DB에 직접 쓰기 작업(회원가입, 곡 등록/삭제, 콘티 편집 등)이 그대로 반영됨. 테스트 데이터를
#    함부로 만들거나 지우지 않도록 주의. 읽기 전용이 목적이면 MCP(.mcp.json, SUPABASE_READONLY_URL)를
#    대신 사용할 것 — 그건 SELECT 전용 역할이라 실수로 데이터를 바꿀 위험이 없음.

spring:
  datasource:
    url: jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres
    username: postgres.<project-ref>
    password: <supabase-db-password>
